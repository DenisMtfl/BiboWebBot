@page "/accounts"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<PageTitle>Konten Konfiguration</PageTitle>

<section class="page-header mb-3">
    <h1>Konten Konfiguration</h1>
    <p class="text-muted mb-0">Hier verwaltest du gespeicherte VÖBB-Konten und markierst Konten für das gleichzeitige Laden.</p>
</section>

@if (appSettingsAccounts.Count > 0)
{
    <div class="alert alert-secondary">
        Zusätzlich sind @appSettingsAccounts.Count Konto/Konten in <code>appsettings*.json</code> unter <code>Voebb:Accounts</code> konfiguriert.
    </div>
}

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @(isError ? "alert-danger" : "alert-info")">@statusMessage</div>
}

<div class="card mb-3">
    <div class="card-body">
        <h2 class="h5 mb-3">Google-Kalender Konfiguration</h2>
        <AuthorizeView>
            <Authorized>
                @if (!string.IsNullOrWhiteSpace(calendarStatusMessage))
                {
                    <div class="alert @(calendarIsError ? "alert-danger" : "alert-info")">@calendarStatusMessage</div>
                }
                <div class="mb-3">
                    <label class="form-label" for="calendarSelect">Google-Kalender</label>
                    <div class="d-flex gap-2">
                        <select id="calendarSelect" class="form-select" @bind="calendarSettings.CalendarId">
                            @if (availableCalendars.Count == 0)
                            {
                                <option value="">-- Kalender laden --</option>
                            }
                            @foreach (var calendar in availableCalendars)
                            {
                                <option value="@calendar.Id">@(calendar.IsPrimary ? $"{calendar.Summary} (Primär)" : calendar.Summary)</option>
                            }
                        </select>
                        <button type="button" class="btn btn-outline-secondary text-nowrap" @onclick="LoadAvailableCalendarsAsync" disabled="@calendarsLoading">
                            @if (calendarsLoading)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            }
                            else
                            {
                                <span>Kalender laden</span>
                            }
                        </button>
                    </div>
                    <div class="form-text">Wähle den Kalender, in den das früheste Rückgabedatum eingetragen werden soll.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="eventNameTemplate">Termin-Name</label>
                    <input id="eventNameTemplate" class="form-control" @bind="calendarSettings.EventSummaryTemplate" placeholder="VÖBB: Früheste Rückgabe {Konto} ({Datum})" />
                    <div class="form-text">Platzhalter: <code>{Konto}</code> für den Kontonamen, <code>{Datum}</code> für das Fälligkeitsdatum.</div>
                </div>
                <button type="button" class="btn btn-primary" @onclick="SaveGoogleCalendarSettingsAsync">Kalender-Einstellungen speichern</button>
            </Authorized>
            <NotAuthorized>
                <div class="alert alert-secondary mb-0">
                    Melde dich zuerst per <a href="/auth/google/login?returnUrl=/accounts">Google Login</a> an, um verfügbare Kalender auszuwählen.
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>

<EditForm Model="@newAccount" OnValidSubmit="AddOrUpdateAccountAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="card mb-3">
        <div class="card-body">
        <div class="mb-3">
            <label class="form-label" for="accountLoginName">Login-Name</label>
            <InputText id="accountLoginName" class="form-control" @bind-Value="newAccount.LoginName" />
        </div>
        <div class="mb-3">
            <label class="form-label" for="accountCardId">Bibliotheksausweis</label>
            <InputText id="accountCardId" class="form-control" @bind-Value="newAccount.CardId" />
        </div>
        <div class="mb-3">
            <label class="form-label" for="accountPassword">Passwort</label>
            <InputText id="accountPassword" class="form-control" type="password" @bind-Value="newAccount.Password" />
        </div>
        <button type="submit" class="btn btn-primary" disabled="@isBusy">Konto speichern</button>
        </div>
    </div>
</EditForm>

@if (savedAccounts.Count == 0)
{
    <p>Noch keine Konten gespeichert.</p>
}
else
{
    <div class="card">
        <div class="card-body">
        <h2 class="h5 mb-3">Gespeicherte Konten</h2>
        @foreach (var account in savedAccounts)
        {
            var cardId = account.CardId ?? string.Empty;
            <div class="d-flex flex-wrap align-items-center justify-content-between border rounded-3 p-3 mb-2 bg-white">
                <div class="d-flex align-items-center gap-2">
                    <span class="fw-semibold">@(string.IsNullOrWhiteSpace(account.LoginName) ? cardId : account.LoginName)</span>
                    <span class="text-muted">(@cardId)</span>
                    <span class="text-muted">(Passwort gespeichert)</span>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="form-check m-0">
                        <input class="form-check-input"
                               type="checkbox"
                               id="pref-@cardId"
                               checked="@selectedBatchCardIds.Contains(cardId)"
                               @onchange="(args) => ToggleBatchSelection(cardId, args.Value)" />
                        <label class="form-check-label" for="pref-@cardId">Für Sammelladen markieren</label>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveAccountAsync(cardId)" disabled="@isBusy">Löschen</button>
                </div>
            </div>
        }

@if (appSettingsAccounts.Count > 0)
{
    <div class="card mt-3">
        <div class="card-body">
        <h2 class="h5 mb-3">Konten aus appsettings (nur Lesen)</h2>
        @foreach (var account in appSettingsAccounts)
        {
            var cardId = account.CardId ?? string.Empty;
            <div class="d-flex flex-wrap align-items-center justify-content-between border rounded-3 p-3 mb-2 bg-white">
                <div class="d-flex align-items-center gap-2">
                    <span class="fw-semibold">@(string.IsNullOrWhiteSpace(account.LoginName) ? cardId : account.LoginName)</span>
                    <span class="text-muted">(@cardId)</span>
                    <span class="text-muted">(Passwort in appsettings)</span>
                </div>
                @if (account.LoadForBatch)
                {
                    <span class="badge text-bg-primary">Für Sammelladen aktiv</span>
                }
                else
                {
                    <span class="badge text-bg-light border">Für Sammelladen aus</span>
                }
            </div>
        }
        </div>
    </div>
}

        <button type="button" class="btn btn-outline-danger mt-2" @onclick="ClearAllAsync" disabled="@isBusy">Alle Konten löschen</button>
        </div>
    </div>
}

@code {
    private const string CredentialsStorageKey = "bibo.credentials";
    private const string BatchSelectionStorageKey = "bibo.batchSelection";
    private const string GoogleCalendarSettingsStorageKey = "bibo.googleCalendarSettings";

    private readonly SavedVoebbAccount newAccount = new();
    private List<SavedVoebbAccount> savedAccounts = [];
    private List<AppSettingsVoebbAccount> appSettingsAccounts = [];
    private HashSet<string> selectedBatchCardIds = [];
    private string statusMessage = string.Empty;
    private bool isError;
    private bool isBusy;
    private bool loaded;

    private readonly GoogleCalendarSettings calendarSettings = new();
    private List<GoogleCalendarInfo> availableCalendars = [];
    private bool calendarsLoading;
    private string calendarStatusMessage = string.Empty;
    private bool calendarIsError;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (loaded)
        {
            return;
        }

        try
        {
            await LoadFromBrowserAsync();
            await LoadGoogleCalendarSettingsFromBrowserAsync();
            loaded = true;
            StateHasChanged();
        }
        catch (InvalidOperationException ex) when (ex.Message.Contains("prerender", StringComparison.OrdinalIgnoreCase))
        {
            // JS interop is not available during prerendering; retry on interactive render.
        }
    }

    private async Task LoadGoogleCalendarSettingsFromBrowserAsync()
    {
        var stored = await JS.InvokeAsync<GoogleCalendarSettings?>("biboCredentialsStorage.loadGoogleCalendarSettings", GoogleCalendarSettingsStorageKey);
        if (stored is not null)
        {
            calendarSettings.CalendarId = stored.CalendarId;
            calendarSettings.EventSummaryTemplate = stored.EventSummaryTemplate;
        }

        if (!string.IsNullOrWhiteSpace(calendarSettings.CalendarId))
        {
            await LoadAvailableCalendarsAsync();
        }
    }

    private async Task LoadAvailableCalendarsAsync()
    {
        calendarsLoading = true;
        calendarStatusMessage = string.Empty;
        calendarIsError = false;
        StateHasChanged();

        var currentSelection = calendarSettings.CalendarId;
        var result = await JS.InvokeAsync<GoogleCalendarListResult?>("biboCredentialsStorage.getGoogleCalendars");
        availableCalendars = result?.Calendars ?? [];

        if (!(result?.IsSuccess ?? false))
        {
            calendarStatusMessage = result?.ErrorMessage ?? "Kalenderliste konnte nicht geladen werden.";
            calendarIsError = true;
        }
        else if (availableCalendars.Count == 0)
        {
            calendarStatusMessage = "Keine Kalender in deinem Google-Konto gefunden.";
            calendarIsError = true;
        }
        else
        {
            calendarStatusMessage = $"{availableCalendars.Count} Kalender geladen.";
            calendarIsError = false;

            var hasCurrentSelection = !string.IsNullOrWhiteSpace(currentSelection)
                && availableCalendars.Any(c => string.Equals(c.Id, currentSelection, StringComparison.Ordinal));

            if (!hasCurrentSelection)
            {
                calendarSettings.CalendarId = availableCalendars.FirstOrDefault(c => c.IsPrimary)?.Id
                    ?? availableCalendars[0].Id;
            }
        }

        calendarsLoading = false;
        StateHasChanged();
    }

    private async Task SaveGoogleCalendarSettingsAsync()
    {
        await JS.InvokeVoidAsync("biboCredentialsStorage.saveGoogleCalendarSettings", GoogleCalendarSettingsStorageKey, calendarSettings);
        calendarStatusMessage = "Kalender-Einstellungen gespeichert.";
        calendarIsError = false;
    }

    private async Task LoadFromBrowserAsync()
    {
        appSettingsAccounts = LoadFromAppSettings();

        savedAccounts = (await JS.InvokeAsync<List<SavedVoebbAccount>?>("biboCredentialsStorage.loadMany", CredentialsStorageKey) ?? [])
            .Where(x => !string.IsNullOrWhiteSpace(x.LoginName)
                && !string.IsNullOrWhiteSpace(x.CardId)
                && !string.IsNullOrWhiteSpace(x.Password))
            .GroupBy(x => x.CardId)
            .Select(g => g.Last())
            .OrderBy(x => x.CardId)
            .ToList();

        var selected = await JS.InvokeAsync<List<string>?>("biboCredentialsStorage.loadSelection", BatchSelectionStorageKey) ?? [];
        selectedBatchCardIds = selected
            .Where(x => savedAccounts.Any(a => string.Equals(a.CardId, x, StringComparison.Ordinal)))
            .ToHashSet(StringComparer.Ordinal);
    }

    private List<AppSettingsVoebbAccount> LoadFromAppSettings()
    {
        var configuredAccounts = Configuration
            .GetSection("Voebb:Accounts")
            .Get<List<AppSettingsVoebbAccount>>() ?? [];

        return configuredAccounts
            .Where(x => !string.IsNullOrWhiteSpace(x.LoginName)
                && !string.IsNullOrWhiteSpace(x.CardId)
                && !string.IsNullOrWhiteSpace(x.Password))
            .GroupBy(x => x.CardId)
            .Select(g => g.Last())
            .OrderBy(x => x.CardId)
            .ToList();
    }

    private async Task AddOrUpdateAccountAsync()
    {
        var cardId = (newAccount.CardId ?? string.Empty).Trim();
        var loginName = (newAccount.LoginName ?? string.Empty).Trim();
        var password = newAccount.Password ?? string.Empty;

        if (string.IsNullOrWhiteSpace(loginName)
            || string.IsNullOrWhiteSpace(cardId)
            || string.IsNullOrWhiteSpace(password))
        {
            statusMessage = "Login-Name, Bibliotheksausweis und Passwort sind erforderlich.";
            isError = true;
            return;
        }

        isBusy = true;
        var existing = savedAccounts.FirstOrDefault(x => string.Equals(x.CardId, cardId, StringComparison.Ordinal));
        if (existing is null)
        {
            savedAccounts.Add(new SavedVoebbAccount
            {
                LoginName = loginName,
                CardId = cardId,
                Password = password
            });
        }
        else
        {
            existing.LoginName = loginName;
            existing.Password = password;
        }

        savedAccounts = savedAccounts.OrderBy(x => x.CardId).ToList();
        await PersistAsync();

        newAccount.LoginName = string.Empty;
        newAccount.CardId = string.Empty;
        newAccount.Password = string.Empty;
        statusMessage = "Konto gespeichert.";
        isError = false;
        isBusy = false;
    }

    private async Task RemoveAccountAsync(string cardId)
    {
        isBusy = true;
        savedAccounts.RemoveAll(x => string.Equals(x.CardId, cardId, StringComparison.Ordinal));
        selectedBatchCardIds.Remove(cardId);
        await PersistAsync();
        statusMessage = "Konto gelöscht.";
        isError = false;
        isBusy = false;
    }

    private async Task ClearAllAsync()
    {
        isBusy = true;
        savedAccounts.Clear();
        selectedBatchCardIds.Clear();
        await JS.InvokeVoidAsync("biboCredentialsStorage.clear", CredentialsStorageKey);
        await JS.InvokeVoidAsync("biboCredentialsStorage.clear", BatchSelectionStorageKey);
        statusMessage = "Alle Konten wurden gelöscht.";
        isError = false;
        isBusy = false;
    }

    private async Task ToggleBatchSelection(string cardId, object? value)
    {
        var isChecked = value as bool? ?? false;
        if (isChecked)
        {
            selectedBatchCardIds.Add(cardId);
        }
        else
        {
            selectedBatchCardIds.Remove(cardId);
        }

        await JS.InvokeVoidAsync("biboCredentialsStorage.saveSelection", BatchSelectionStorageKey, selectedBatchCardIds.ToList());
    }

    private async Task PersistAsync()
    {
        await JS.InvokeVoidAsync("biboCredentialsStorage.saveMany", CredentialsStorageKey, savedAccounts);
        selectedBatchCardIds.RemoveWhere(cardId => savedAccounts.All(x => !string.Equals(x.CardId, cardId, StringComparison.Ordinal)));
        await JS.InvokeVoidAsync("biboCredentialsStorage.saveSelection", BatchSelectionStorageKey, selectedBatchCardIds.ToList());
    }
}